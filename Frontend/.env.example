# Backend API base URL (no trailing slash). Required for API requests.
# Production (Vercel): set to your Render backend URL, e.g.:
NEXT_PUBLIC_API_BASE_URL=https://elsielashstudiobackend.onrender.com
# Local dev: use http://localhost:5001 in .env.local

# Admin login password (client-side; use a strong value in production).
# Required to access /admin after logging in at /admin/login.
NEXT_PUBLIC_ADMIN_PASSWORD=
